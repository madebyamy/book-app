# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# URL of your deployed chat backend function (see /server/chat-example.js)
# Leave blank to disable the "Down the rabbit hole" chat feature.
VITE_CHAT_ENDPOINT=

# Login passwords for each user (set these in Netlify environment variables)
VITE_PASSWORD_AMY=
VITE_PASSWORD_LYNNELL=
VITE_PASSWORD_CHRISTINA=

# Supabase — enables cross-device sync and real-time chat
# Get these from supabase.com → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
